@* Views/Reports/AllExpensesReport.cshtml - All Expenses Report *@
@using ProjectManagement.Controllers
@{
    ViewData["Title"] = "All Expenses Report";
    var expenses = ViewBag.Expenses as List<ExpenseReportRow>;
    var expenseSummary = ViewBag.ExpenseSummary as IEnumerable<ExpenseSummaryItem>;
    var fromDate = (DateTime)ViewBag.FromDate;
    var toDate = (DateTime)ViewBag.ToDate;
    var totalExpenses = (decimal)(ViewBag.TotalExpenses ?? 0);
    var totalHazri = (decimal)(ViewBag.TotalHazri ?? 0);
    var totalPurchaseDeductions = (decimal)(ViewBag.TotalPurchaseDeductions ?? 0);
    var openingBalance = (decimal)(ViewBag.OpeningBalance ?? 0);
    var netTotal = (decimal)(ViewBag.NetTotal ?? 0);
    var selectedVoucherType = ViewBag.SelectedVoucherType as string;
}

<div class="d-print-none">
    <h2><i class="bi bi-receipt"></i> All Expenses Report</h2>
    <p class="text-muted">View all expenses in one place</p>
</div>

<!-- Filter Form -->
<div class="card mb-3 d-print-none">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-filter"></i> Filter Options</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-2">
                <label class="form-label">From Date</label>
                <input type="date" name="fromDate" value="@fromDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">To Date</label>
                <input type="date" name="toDate" value="@toDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Filter by Project</label>
                @Html.DropDownList("projectId", ViewBag.Projects as SelectList, "-- All Projects --", new { @class = "form-select" })
            </div>
            <div class="col-md-3">
                <label class="form-label">Filter by Expense Head</label>
                @Html.DropDownList("expenseHeadId", ViewBag.ExpenseHeads as SelectList, "-- All Expense Heads --", new { @class = "form-select" })
            </div>
            <div class="col-md-2">
                <label class="form-label">Filter by Voucher Type</label>
                <select name="voucherType" class="form-select">
                    <option value="">-- All Types --</option>
                    <option value="Expense" selected="@(selectedVoucherType == "Expense")">Expense</option>
                    <option value="Hazri" selected="@(selectedVoucherType == "Hazri")">Hazri</option>
                    <option value="Purchase" selected="@(selectedVoucherType == "Purchase")">Purchase</option>
                </select>
            </div>
            <div class="col-md-12">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-search"></i> Generate
                </button>
                <a asp-action="AllExpensesReport" class="btn btn-secondary">
                    <i class="bi bi-x-circle"></i> Clear
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Summary Cards -->
<div class="row mb-3">
    <div class="col-md-3">
        <div class="card bg-secondary text-white">
            <div class="card-body text-center">
                <h6>Opening Balance</h6>
                <h3>Rs. @string.Format("{0:N0}", openingBalance)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h6>Total Expenses</h6>
                <h3>Rs. @string.Format("{0:N0}", totalExpenses)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body text-center">
                <h6>Total Hazri (Deducted)</h6>
                <h3>Rs. @string.Format("{0:N0}", totalHazri)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h6>Net Total (Expense - Hazri)</h6>
                <h3>Rs. @string.Format("{0:N0}", netTotal)</h3>
            </div>
        </div>
    </div>
</div>

<!-- Expense Summary by Head -->
@if (expenseSummary != null && expenseSummary.Any())
{
    var maxAbsTotal = expenseSummary.Max(s => Math.Abs(s.Total));
    <div class="card mb-3">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0"><i class="bi bi-pie-chart"></i> Expense Summary by Head (Net: Expense âˆ’ Hazri âˆ’ Purchase)</h5>
        </div>
        <div class="card-body">
            <div class="row">
                @foreach (var summary in expenseSummary)
                {
                    var net         = summary.Total;
                    var absNet      = Math.Abs(net);
                    var barPct      = maxAbsTotal > 0 ? (double)(absNet / maxAbsTotal * 100) : 0;
                    var isNegative  = net < 0;
                    var badgeClass  = isNegative ? "bg-success" : "bg-danger";
                    var barColor    = isNegative ? "bg-success" : "bg-danger";
                    var label       = isNegative ? "Net Saving" : "Net Cost";

                    <div class="col-md-4 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-semibold">@summary.ExpenseHead</span>
                            <span class="badge @badgeClass">
                                @(isNegative ? "-" : "")Rs. @string.Format("{0:N0}", absNet)
                                <small>(@label)</small>
                            </span>
                        </div>
                        @if (summary.ExpenseAmount > 0 || summary.HazriAmount > 0 || summary.PurchaseAmount > 0)
                        {
                            <div class="text-muted" style="font-size:11px;" class="mb-1">
                                <span class="text-danger">+@string.Format("{0:N0}", summary.ExpenseAmount)</span>
                                @if (summary.HazriAmount > 0)
                                {
                                    <span class="text-warning ms-1">âˆ’@string.Format("{0:N0}", summary.HazriAmount) Hazri</span>
                                }
                                @if (summary.PurchaseAmount > 0)
                                {
                                    <span class="text-primary ms-1">âˆ’@string.Format("{0:N0}", summary.PurchaseAmount) Purchase</span>
                                }
                            </div>
                        }
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar @barColor"
                                 role="progressbar"
                                 style="width: @barPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"
                                 title="@label: Rs. @string.Format("{0:N0}", absNet)">
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Expenses Table -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-list-ul"></i> Expense Details (@fromDate.ToString("dd-MMM-yyyy") to @toDate.ToString("dd-MMM-yyyy"))</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-sm" id="expensesTable">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Transaction No</th>
                        <th>Source</th>
                        <th>Expense Head</th>
                        <th>Details</th>
                        <th>Project</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Rate</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (openingBalance != 0)
                        {
                            <tr class="table-info fw-bold">
                                <td colspan="8">Opening Balance (before @fromDate.ToString("dd-MMM-yyyy"))</td>
                                <td class="text-end @(openingBalance < 0 ? "text-success" : "text-danger")">
                                    @(openingBalance < 0 ? "(-) " : "")Rs. @string.Format("{0:N0}", Math.Abs(openingBalance))
                                </td>
                            </tr>
                        }
                    }
                    @if (expenses != null && expenses.Any())
                    {
                        foreach (var e in expenses)
                        {
                            var rowClass = e.Source == "Hazri" ? "table-warning" : (e.Source == "Purchase" ? "table-primary" : "");
                            var badgeClass = e.Source == "Hazri" ? "bg-warning text-dark" : (e.Source == "Purchase" ? "bg-primary" : "bg-danger");
                            <tr class="@rowClass">
                                <td>@e.VoucherDate.ToPkShortDate()</td>
                                <td>
                                    <a asp-controller="Vouchers" asp-action="Details" asp-route-id="@e.VoucherId">@e.TransactionNumber</a>
                                </td>
                                <td>
                                    <span class="badge @badgeClass">@e.Source</span>
                                </td>
                                <td>@e.ExpenseHeadName</td>
                                <td>@e.Details</td>
                                <td>
                                    @if (e.ProjectId.HasValue)
                                    {
                                        <a asp-controller="Reports" asp-action="ProjectReport" asp-route-projectId="@e.ProjectId">@e.ProjectName</a>
                                    }
                                </td>
                                <td class="text-end">@(e.Quantity.HasValue ? e.Quantity.Value.ToString("N2") : "-")</td>
                                <td class="text-end">@(e.Rate.HasValue ? e.Rate.Value.ToString("N2") : "-")</td>
                                <td class="text-end fw-bold @(e.Source == "Hazri" || e.Source == "Purchase" ? "text-warning" : "text-danger")">
                                    @if (e.Source == "Hazri" || e.Source == "Purchase")
                                    {
                                        <span>(-) Rs. @string.Format("{0:N0}", e.Amount)</span>
                                    }
                                    else
                                    {
                                        <span>Rs. @string.Format("{0:N0}", e.Amount)</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center">No expenses found for the selected criteria.</td>
                        </tr>
                    }
                </tbody>
                @if (expenses != null && expenses.Any())
                {
                    <tfoot class="table-dark">
                        @if (openingBalance != 0)
                        {
                            <tr class="table-info">
                                <th colspan="8" class="text-end">Opening Balance:</th>
                                <th class="text-end @(openingBalance < 0 ? "text-success" : "")">
                                    @(openingBalance < 0 ? "(-) " : "")Rs. @string.Format("{0:N0}", Math.Abs(openingBalance))
                                </th>
                            </tr>
                        }
                        <tr>
                            <th colspan="8" class="text-end">Total Expenses:</th>
                            <th class="text-end">Rs. @string.Format("{0:N0}", totalExpenses)</th>
                        </tr>
                        <tr class="table-warning">
                            <th colspan="8" class="text-end">Less: Hazri:</th>
                            <th class="text-end">(-) Rs. @string.Format("{0:N0}", totalHazri)</th>
                        </tr>
                        <tr class="table-warning">
                            <th colspan="8" class="text-end">Less: Purchase Expense Deductions:</th>
                            <th class="text-end">(-) Rs. @string.Format("{0:N0}", totalPurchaseDeductions)</th>
                        </tr>
                        <tr class="table-success">
                            <th colspan="8" class="text-end">Net Total:</th>
                            <th class="text-end">Rs. @string.Format("{0:N0}", netTotal)</th>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>

<div class="mt-3 d-print-none">
    <button onclick="window.print()" class="btn btn-primary">
        <i class="bi bi-printer"></i> Print
    </button>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

