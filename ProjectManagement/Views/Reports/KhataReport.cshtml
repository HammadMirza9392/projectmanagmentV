        background: #fff;
        padding: 5px 16px;
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: bold;
        margin-top: 6px;
        direction: rtl;
    }
    .date-range-header {
        text-align: center;
        font-weight: bold;
        font-size: 13px;
        border: 1px solid #ccc;
        padding: 3px;
        background: #fafafa;
        direction: ltr;
    }
    .khata-table tr {
        page-break-inside: avoid;
    }
    .balance-box, .net-balance-box {
        page-break-inside: avoid;
    }
    .khata-section-header {
        page-break-after: avoid;
    }
    @@media print {
        .d-print-none { display: none !important; }
        .khata-page { padding: 0; }
        body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .khata-table tr { page-break-inside: avoid; }
        .balance-box, .net-balance-box { page-break-inside: avoid; }
    }
</style>
}

