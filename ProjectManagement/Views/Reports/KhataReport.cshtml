@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    // Make the Customer dropdown a searchable, type-to-filter box
    $(document).ready(function () {
        $('.select2-customer').select2({
            theme: 'bootstrap-5',
            width: '100%',
            placeholder: 'Search customer... / Ú©Ø³Ù¹Ù…Ø± ØªÙ„Ø§Ø´ Ú©Ø±ÛŒÚº',
            allowClear: true
        });
    });

    // Site branding for the PDF footer (set in Theme Settings, saved to sitesettings.json)
    var SITE = {
        name: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.SiteName)),
        showDev: @(site.ShowDeveloperInfo ? "true" : "false"),
        devName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.DeveloperName)),
        devContact: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.DeveloperContact))
    };

    function buildSiteFooter() {
        var wrap = document.createElement('div');
        wrap.style.cssText = 'margin-top:14px;padding-top:8px;border-top:1px solid #999;text-align:center;font-family:Arial,sans-serif;direction:ltr;';

        var line1 = document.createElement('div');
        line1.style.cssText = 'font-size:11px;color:#333;font-weight:600;';
        line1.textContent = 'This report was generated by ' + SITE.name + ' Management System';
        wrap.appendChild(line1);

        if (SITE.showDev) {
            var line2 = document.createElement('div');
            line2.style.cssText = 'font-size:10px;color:#666;margin-top:3px;';
            line2.textContent = 'Software developed by ' + SITE.devName + ' - Contact: ' + SITE.devContact + ' for the management software';
            wrap.appendChild(line2);
        }
        return wrap;
    }

    function downloadPDF() {
        // Clone the report so we can append the footer without altering the visible page.
        var element = document.getElementById('khataContent').cloneNode(true);
        element.appendChild(buildSiteFooter());

        var customerName = '@(ViewBag.Customer != null ? (ViewBag.Customer as ProjectManagement.Models.Customer)?.Name : "Khata")';
        var fromDate = '@(ViewBag.FromDate != null ? ((DateTime)ViewBag.FromDate).ToString("ddMMyyyy") : "")';
        var toDate = '@(ViewBag.ToDate != null ? ((DateTime)ViewBag.ToDate).ToString("ddMMyyyy") : "")';
        var fileName = 'KhataReport_' + customerName.replace(/\s+/g, '_') + '_' + fromDate + '_' + toDate + '.pdf';

        var opt = {
            margin: [8, 6, 8, 6],
            filename: fileName,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true, logging: false, scrollY: 0 },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
            pagebreak: { mode: ['avoid-all', 'css', 'legacy'] }
        };

        html2pdf().set(opt).from(element).save();
    }
</script>
}

