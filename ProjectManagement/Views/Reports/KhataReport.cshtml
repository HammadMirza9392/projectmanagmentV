    }
    .khata-table td.text-right { text-align: right; }
    .khata-table td.text-left { text-align: left; }
    /* Detail columns: wrap long text onto a second line instead of widening
       the column. Caps the width and breaks long words so the table stays fixed. */
    .khata-table th.detail-col,
    .khata-table td.detail-col {
        white-space: normal;
        word-break: break-word;
        overflow-wrap: anywhere;
        max-width: 180px;
        min-width: 120px;
    }
    .khata-table tr.total-row td {
        background: #f5f5f5;
        font-weight: bold;
        border-top: 2px solid #555;
    }
    .khata-table tr.opening-row td {
        background: #fffde7;
        font-style: italic;
    }
    .balance-box {
        border: 2px solid #333;
        padding: 6px 12px;
        margin-top: 8px;
        background: #f9f9f9;
        direction: rtl;
    }
    .balance-box table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }
    .balance-box table td { padding: 3px 8px; }
    .balance-box .bal-label { font-weight: bold; text-align: right; }
    .balance-box .bal-value { text-align: left; font-weight: bold; }
    .balance-final {
