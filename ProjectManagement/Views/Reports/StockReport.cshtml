@* Views/Reports/StockReport.cshtml *@
@model IEnumerable<ProjectManagement.Models.Item>
@inject ProjectManagement.Services.SiteSettingsService SiteSettings
@{
    ViewData["Title"] = "Stock Report";
    var site = SiteSettings.Get();
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var displayFromDate = fromDate?.ToString("yyyy-MM-dd") ?? "";
    var displayToDate = toDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd");
    var showMovement = ViewBag.ShowMovement != null ? (bool)ViewBag.ShowMovement : false;
    var stockMovements = ViewBag.StockMovements as IEnumerable<ProjectManagement.Controllers.StockMovement>;
    var totalValue = Model?.Sum(i => i.CurrentStock * i.DefaultRate) ?? 0;
}

<div class="d-print-none">
    <h2><i class="bi bi-box-seam"></i> Stock Report</h2>

    <!-- Filter Section -->
    <div class="card mb-3">
        <div class="card-header bg-light">
            <h6 class="mb-0"><i class="bi bi-funnel"></i> Filter Options</h6>
        </div>
        <div class="card-body">
            <form method="get" asp-action="StockReport" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label"><i class="bi bi-calendar"></i> From Date</label>
                    <input type="date" name="fromDate" class="form-control" value="@displayFromDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label"><i class="bi bi-calendar"></i> To Date</label>
                    <input type="date" name="toDate" class="form-control" value="@displayToDate" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> View Stock
                    </button>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <a asp-action="StockReport" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-x-circle"></i> Show All
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@if (showMovement && stockMovements != null)
{
    <!-- Date-filtered stock movement view -->
    <div class="card mb-3">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">
                <i class="bi bi-boxes"></i> Stock Movement Summary
            </h5>
            <small>Period: @fromDate?.ToString("dd-MMM-yyyy") to @toDate?.ToString("dd-MMM-yyyy")</small>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="text-muted">Total Items</h6>
                            <h3 class="text-primary">@(stockMovements.Count())</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="text-muted">Total Purchased (Qty)</h6>
                            <h3 class="text-success">@string.Format("{0:N2}", stockMovements.Sum(s => s.PurchaseQty))</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="text-muted">Total Sold (Qty)</h6>
                            <h3 class="text-danger">@string.Format("{0:N2}", stockMovements.Sum(s => s.SaleQty))</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="text-muted">Net Stock Change</h6>
                            <h3 class="text-info">@string.Format("{0:N2}", stockMovements.Sum(s => s.PurchaseQty - s.SaleQty))</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Stock Movement Details</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0" id="stockTable">
                    <thead class="table-primary">
                        <tr>
                            <th class="fw-bold" style="font-size: 14px;">#</th>
                            <th class="fw-bold" style="font-size: 14px;">Item Name</th>
                            <th class="fw-bold" style="font-size: 14px;">Unit</th>
                            <th class="text-end fw-bold" style="font-size: 14px;">Opening Stock</th>
                            <th class="text-end fw-bold" style="font-size: 14px;">Purchased</th>
                            <th class="text-end fw-bold" style="font-size: 14px;">Sold</th>
                            <th class="text-end fw-bold" style="font-size: 14px;">Closing Stock</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                            foreach (var sm in stockMovements.OrderBy(s => s.Item.Name))
                            {
                                var trackUrl = Url.Action("StockTrackReport", "Reports", new { itemId = sm.Item.Id, fromDate = fromDate?.ToString("yyyy-MM-dd"), toDate = toDate?.ToString("yyyy-MM-dd") });
                                <tr style="font-size: 13px; cursor: pointer;" onclick="window.location='@trackUrl'" title="Click to view all transactions for @sm.Item.Name">
                                    <td class="align-middle">@counter</td>
                                    <td class="align-middle"><strong class="text-primary">@sm.Item.Name</strong></td>
                                    <td class="align-middle">@(sm.Item.Unit ?? "N/A")</td>
                                    <td class="text-end align-middle">@string.Format("{0:N3}", sm.OpeningStock)</td>
                                    <td class="text-end align-middle text-success fw-semibold">@string.Format("{0:N3}", sm.PurchaseQty)</td>
                                    <td class="text-end align-middle text-danger fw-semibold">@string.Format("{0:N3}", sm.SaleQty)</td>
                                    <td class="text-end align-middle fw-bold @(sm.ClosingStock > 0 ? "text-success" : sm.ClosingStock < 0 ? "text-danger" : "")">
                                        @string.Format("{0:N3}", sm.ClosingStock)
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                    </tbody>
                    <tfoot class="table-success">
                        <tr style="font-size: 15px;">
                            <th colspan="3" class="text-end fw-bold py-3">TOTALS:</th>
                            <th class="text-end fw-bold py-3">@string.Format("{0:N2}", stockMovements.Sum(s => s.OpeningStock))</th>
                            <th class="text-end fw-bold py-3 text-success">@string.Format("{0:N2}", stockMovements.Sum(s => s.PurchaseQty))</th>
                            <th class="text-end fw-bold py-3 text-danger">@string.Format("{0:N2}", stockMovements.Sum(s => s.SaleQty))</th>
                            <th class="text-end fw-bold py-3">@string.Format("{0:N2}", stockMovements.Sum(s => s.ClosingStock))</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <!-- Default: show current stock -->
    <div class="card mb-3">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">
                <i class="bi bi-boxes"></i> Stock Summary
            </h5>
            <small>As of: @DateTime.Now.ToString("dd-MMM-yyyy hh:mm tt")</small>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="text-muted">Total Items</h6>
                            <h3 class="text-primary">@(Model?.Count() ?? 0)</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="text-muted">Items in Stock</h6>
                            <h3 class="text-success">@(Model?.Count(i => i.CurrentStock > 0) ?? 0)</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="text-muted">Out of Stock</h6>
                            <h3 class="text-danger">@(Model?.Count(i => i.CurrentStock <= 0) ?? 0)</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="text-muted">Total Stock Value</h6>
                            <h3 class="text-info">Rs. @string.Format("{0:N0}", totalValue)</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Stock Details</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0" id="stockTable">
                    <thead class="table-primary">
                        <tr>
                            <th class="fw-bold" style="font-size: 14px;">#</th>
                            <th class="fw-bold" style="font-size: 14px;">Item Name</th>
                            <th class="fw-bold" style="font-size: 14px;">Unit</th>
                            <th class="text-end fw-bold" style="font-size: 14px;">Current Stock</th>
                            <th class="text-end fw-bold" style="font-size: 14px;">Default Rate</th>
                            <th class="text-end fw-bold" style="font-size: 14px;">Stock Value</th>
                            <th class="fw-bold" style="font-size: 14px;">Status</th>
                            <th class="fw-bold" style="font-size: 14px;">Stock Level</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int counter = 1;
                            foreach (var item in Model.OrderBy(i => i.Name))
                            {
                                var stockValue = item.CurrentStock * item.DefaultRate;
                                var stockStatus = item.CurrentStock > 50 ? "Sufficient" :
                                item.CurrentStock > 10 ? "Low" :
                                item.CurrentStock > 0 ? "Critical" : "Out of Stock";
                                var statusColor = item.CurrentStock > 50 ? "success" :
                                item.CurrentStock > 10 ? "warning" :
                                item.CurrentStock > 0 ? "danger" : "dark";
                                var trackUrl = Url.Action("StockTrackReport", "Reports", new { itemId = item.Id });

                                <tr style="font-size: 13px; cursor: pointer;" onclick="window.location='@trackUrl'" title="Click to view all transactions for @item.Name">
                                    <td class="align-middle">@counter</td>
                                    <td class="align-middle">
                                        <strong class="text-primary">@item.Name</strong>
                                        @if (!item.StockTrackingEnabled)
                                        {
                                            <span class="badge bg-secondary ms-2" style="font-size: 11px;">No Tracking</span>
                                        }
                                    </td>
                                    <td class="align-middle">@(item.Unit ?? "N/A")</td>
                                    <td class="text-end align-middle @(item.CurrentStock <= 10 ? "text-danger fw-bold" : "fw-semibold")">
                                        @string.Format("{0:N3}", item.CurrentStock)
                                    </td>
                                    <td class="text-end align-middle">Rs. @string.Format("{0:N0}", item.DefaultRate)</td>
                                    <td class="text-end align-middle fw-bold text-success">Rs. @string.Format("{0:N0}", stockValue)</td>
                                    <td class="align-middle">
                                        <span class="badge bg-@statusColor" style="font-size: 11px;">@stockStatus</span>
                                    </td>
                                    <td class="align-middle">
                                        <div class="progress" style="height: 20px;">
                                            @{
                                                var percentage = Math.Min((item.CurrentStock / 100) * 100, 100);
                                            }
                                            <div class="progress-bar bg-@statusColor" role="progressbar"
                                                 style="width: @percentage%;"
                                                 aria-valuenow="@item.CurrentStock"
                                                 aria-valuemin="0" aria-valuemax="100">
                                                @string.Format("{0:N1}", item.CurrentStock)
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4 fst-italic">
                                    <i class="bi bi-info-circle"></i> No items with stock tracking enabled found.
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-success">
                        <tr style="font-size: 15px;">
                            <th colspan="5" class="text-end fw-bold py-3">TOTAL STOCK VALUE:</th>
                            <th class="text-end fw-bold py-3 text-success">Rs. @string.Format("{0:N0}", totalValue)</th>
                            <th colspan="2"></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}

<div class="mt-3 d-print-none">
    <button onclick="window.print()" class="btn btn-primary">
        <i class="bi bi-printer"></i> Print Report
    </button>
    <button onclick="exportTableToExcel('stockTable', 'StockReport_@DateTime.Now.ToString("yyyyMMdd")')" class="btn btn-success">
        <i class="bi bi-file-earmark-excel"></i> Export to Excel
    </button>
    <button onclick="generatePDF()" class="btn btn-danger">
        <i class="bi bi-file-pdf"></i> Generate PDF
    </button>
    <a asp-controller="Reports" asp-action="ExportToExcel" asp-route-reportType="stock" class="btn btn-warning">
        <i class="bi bi-download"></i> Download Full Report
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

@section Scripts {
    <!-- html2pdf.js CDN (screenshot-style PDF) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        // Site branding for the PDF footer (set in Theme Settings, saved to sitesettings.json)
        var SITE = {
            name: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.SiteName)),
            showDev: @(site.ShowDeveloperInfo ? "true" : "false"),
            devName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.DeveloperName)),
            devContact: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.DeveloperContact))
        };

        // Builds the site-name + (optional) developer footer block appended to the
        // bottom of the cloned report so it appears in the screenshot-style PDF.
        function buildSiteFooter() {
            var wrap = document.createElement('div');
            wrap.style.cssText = 'margin-top:14px;padding-top:8px;border-top:1px solid #999;text-align:center;font-family:Arial,sans-serif;';

            var line1 = document.createElement('div');
            line1.style.cssText = 'font-size:11px;color:#333;font-weight:600;';
            line1.textContent = 'This report was generated by ' + SITE.name + ' Management System';
            wrap.appendChild(line1);

            if (SITE.showDev) {
                var line2 = document.createElement('div');
                line2.style.cssText = 'font-size:10px;color:#666;margin-top:3px;';
                line2.textContent = 'Software developed by ' + SITE.devName + ' â€” Contact: ' + SITE.devContact + ' for the management software';
                wrap.appendChild(line2);
            }
            return wrap;
        }

        $(document).ready(function() {
            $('#stockTable').DataTable({
                "order": [[1, "asc"]],
                // Show all rows on one page (no pagination / no scrolling) so the full
                // table is always visible and every row is captured in the PDF.
                "paging": false,
                "info": false,
                "columnDefs": [
                    { "orderable": false, "targets": [0] }
                ]
            });
        });

        // Builds a clean clone of just the report, expanded so html2pdf captures every
        // row and column, with the site footer appended at the bottom.
        function buildPdfElement() {
            const element = document.querySelector('body').cloneNode(true);
            element.style.display = 'block';
            element.style.height = 'auto';

            // Strip site chrome, screen-only controls, and the DataTables search/length bars.
            element.querySelectorAll('header, footer, .modal, .d-print-none, .dataTables_filter, .dataTables_length, .dataTables_paginate, .dataTables_info')
                   .forEach(el => el.remove());

            element.querySelectorAll('.table-responsive').forEach(function(el) {
                el.style.maxHeight = 'none';
                el.style.overflow = 'visible';
                el.style.overflowX = 'visible';
                el.style.overflowY = 'visible';
            });

            element.querySelectorAll('#stockTable thead').forEach(t => t.style.display = 'table-header-group');
            element.querySelectorAll('#stockTable thead th').forEach(th => th.style.position = 'static');
            element.querySelectorAll('#stockTable tfoot').forEach(t => t.style.display = 'table-footer-group');

            element.querySelectorAll('#stockTable').forEach(function(tbl) {
                tbl.style.width = '100%';
            });
            element.querySelectorAll('#stockTable th, #stockTable td').forEach(function(cell) {
                cell.style.wordBreak = 'break-word';
                cell.style.whiteSpace = 'normal';
                cell.style.overflowWrap = 'anywhere';
                cell.style.fontSize = '11px';
                cell.style.padding = '4px 5px';
                cell.style.verticalAlign = 'middle';
            });

            var main = element.querySelector('main') || element.querySelector('.container-fluid') || element;
            main.appendChild(buildSiteFooter());

            return element;
        }

        // Generate the screenshot-style PDF (all rows + columns), with the site footer.
        function generatePDF() {
            const button = event.target.closest('button');
            const originalText = button.innerHTML;
            button.innerHTML = '<i class="bi bi-hourglass-split"></i> Generating PDF...';
            button.disabled = true;

            const timestamp = new Date().toISOString().slice(0,10).replace(/-/g,'');
            const filename = 'StockReport_' + timestamp + '.pdf';

            const element = buildPdfElement();
            const opt = {
                margin: [10, 10, 10, 10],
                filename: filename,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true, logging: false, scrollY: 0, scrollX: 0, windowHeight: element.scrollHeight },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' },
                pagebreak: { mode: ['css', 'legacy'], avoid: 'tr' }
            };

            html2pdf().set(opt).from(element).save().then(function() {
                button.innerHTML = originalText;
                button.disabled = false;
            }).catch(function(error) {
                console.error('PDF generation error:', error);
                button.innerHTML = originalText;
                button.disabled = false;
            });
        }

        function exportTableToExcel(tableID, filename = ''){
            var downloadLink;
            var dataType = 'application/vnd.ms-excel';
            var tableSelect = document.getElementById(tableID);
            var tableHTML = tableSelect.outerHTML.replace(/ /g, '%20');

            filename = filename?filename+'.xls':'excel_data.xls';
            downloadLink = document.createElement("a");
            document.body.appendChild(downloadLink);

            if(navigator.msSaveOrOpenBlob){
                var blob = new Blob(['\ufeff', tableHTML], {
                    type: dataType
                });
                navigator.msSaveOrOpenBlob( blob, filename);
            }else{
                downloadLink.href = 'data:' + dataType + ', ' + tableHTML;
                downloadLink.download = filename;
                downloadLink.click();
            }
        }
    </script>

    <style>
        /* Enhanced table styling */
        #stockTable thead th {
            background-color: #cfe2ff !important;
            border-bottom: 2px solid #0d6efd;
            padding: 12px 8px;
        }

        #stockTable tbody tr:hover {
            background-color: #dbeafe;
        }

        #stockTable {
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        /* No fixed-height scroll container â€” the table expands to show every row
           so all records are visible on screen and captured in the PDF. */
        .table-responsive {
            max-height: none;
            overflow: visible;
        }

        @@media print {
            .table {
                font-size: 10pt;
            }

            .progress {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .table-responsive {
                max-height: none;
                overflow: visible;
            }

            #stockTable thead th {
                position: static;
            }

            #stockTable thead {
                display: table-header-group;
            }

            #stockTable tfoot {
                display: table-footer-group;
            }

            #stockTable tr {
                page-break-inside: avoid;
            }
        }
    </style>
}

