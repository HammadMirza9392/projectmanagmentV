                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Revoked Vouchers -->
<div class="card mb-3">
    <div class="card-header text-dark d-flex justify-content-between align-items-center" style="background-color:#ffc107;">
        <h5 class="mb-0"><i class="bi bi-slash-circle"></i> Entries Revoked on @activityDate.ToString("dd-MMM-yyyy")</h5>
        <span class="badge bg-white text-dark">@totalRevoked entries</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-warning">
                    <tr>
                        <th>Time Revoked</th>
                        <th>Voucher No</th>
                        <th>Type</th>
                        <th>Party</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Rate</th>
                        <th class="text-end">Amount</th>
                        <th>Created By</th>
                        <th>Revoked By</th>
                    </tr>
                </thead>
                <tbody>
                    @if (revokedVouchers != null && revokedVouchers.Any())
                    {
                        foreach (var v in revokedVouchers)
                        {
                            var party = v.PurchasingCustomer?.Name ?? v.ReceivingCustomer?.Name ?? "-";
                            <tr>
                                <td><span class="badge bg-warning text-dark">@(v.RevokedDate.HasValue ? v.RevokedDate.Value.ToString("HH:mm") : "-")</span></td>
                                <td><a asp-controller="Vouchers" asp-action="Details" asp-route-id="@v.Id">@v.TransactionNumber</a></td>
                                <td>
                                    <span class="badge bg-@(v.VoucherType == ProjectManagement.Models.VoucherType.Purchase ? "primary" :
                                                           v.VoucherType == ProjectManagement.Models.VoucherType.Sale ? "success" :
                                                           v.VoucherType == ProjectManagement.Models.VoucherType.Expense ? "danger" :
                                                           v.VoucherType == ProjectManagement.Models.VoucherType.Hazri ? "warning" : "secondary")">
                                        @v.VoucherType
                                    </span>
                                </td>
                                <td>@party</td>
                                <td class="text-end">@(v.Quantity.HasValue ? v.Quantity.Value.ToString("#,##0.###") : "-")</td>
                                <td class="text-end">@(v.Rate.HasValue ? v.Rate.Value.ToString("#,##0.##") : "-")</td>
                                <td class="text-end">@string.Format("{0:N0}", v.Amount)</td>
                                <td>@(v.CreatedBy ?? "N/A")</td>
                                <td><span class="badge bg-warning text-dark">@(v.RevokedBy ?? "System")</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted fst-italic py-3">
                                <i class="bi bi-info-circle"></i> No entries were revoked on @activityDate.ToString("dd-MMM-yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Restored Vouchers -->
<div class="card mb-3">
    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-arrow-counterclockwise"></i> Entries Restored on @activityDate.ToString("dd-MMM-yyyy")</h5>
        <span class="badge bg-white text-info">@totalRestored entries</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-info">
                    <tr>
                        <th>Time Restored</th>
                        <th>Voucher No</th>
                        <th>Type</th>
                        <th>Party</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Rate</th>
                        <th class="text-end">Amount</th>
                        <th>Created By</th>
                        <th>Restored By</th>
                    </tr>
                </thead>
                <tbody>
                    @if (restoredVouchers != null && restoredVouchers.Any())
                    {
                        foreach (var v in restoredVouchers)
                        {
                            var party = v.PurchasingCustomer?.Name ?? v.ReceivingCustomer?.Name ?? "-";
                            <tr>
                                <td><span class="badge bg-info">@(v.RestoredDate.HasValue ? v.RestoredDate.Value.ToString("HH:mm") : "-")</span></td>
                                <td><a asp-controller="Vouchers" asp-action="Details" asp-route-id="@v.Id">@v.TransactionNumber</a></td>
                                <td>
                                    <span class="badge bg-@(v.VoucherType == ProjectManagement.Models.VoucherType.Purchase ? "primary" :
                                                           v.VoucherType == ProjectManagement.Models.VoucherType.Sale ? "success" :
                                                           v.VoucherType == ProjectManagement.Models.VoucherType.Expense ? "danger" :
                                                           v.VoucherType == ProjectManagement.Models.VoucherType.Hazri ? "warning" : "secondary")">
                                        @v.VoucherType
                                    </span>
                                </td>
                                <td>@party</td>
                                <td class="text-end">@(v.Quantity.HasValue ? v.Quantity.Value.ToString("#,##0.###") : "-")</td>
                                <td class="text-end">@(v.Rate.HasValue ? v.Rate.Value.ToString("#,##0.##") : "-")</td>
                                <td class="text-end">@string.Format("{0:N0}", v.Amount)</td>
                                <td>@(v.CreatedBy ?? "N/A")</td>
                                <td><span class="badge bg-info">@(v.RestoredBy ?? "System")</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted fst-italic py-3">
                                <i class="bi bi-info-circle"></i> No entries were restored on @activityDate.ToString("dd-MMM-yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3 d-print-none">
    <button onclick="window.print()" class="btn btn-primary">
        <i class="bi bi-printer"></i> Print Log
    </button>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

@section Scripts {
    <style>
        @@media print {
            .card { page-break-inside: avoid; }
        }
    </style>
}

