    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0" id="updatedTable">
                <thead class="table-warning">
                    <tr>
                        <th>Time Updated</th>
                        <th>Voucher No</th>
                        <th>Type</th>
                        <th>Voucher Date</th>
                        <th>Customer</th>
                        <th>Item</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Rate</th>
                        <th>Project</th>
