<div class="card mb-3">
    <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-trash"></i> Entries Deleted on @activityDate.ToString("dd-MMM-yyyy")</h5>
        <span class="badge bg-white text-danger">@totalDeleted entries</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0" id="deletedTable">
                <thead class="table-danger">
                    <tr>
                        <th>Time Deleted</th>
                        <th>Voucher No</th>
                        <th>Type</th>
