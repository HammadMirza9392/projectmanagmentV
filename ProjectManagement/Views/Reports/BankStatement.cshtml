@* Views/Reports/BankStatement.cshtml *@
@inject ProjectManagement.Services.SiteSettingsService SiteSettings
@{
    ViewData["Title"] = "Bank Statement";
    var site = SiteSettings.Get();
    var bank = ViewBag.Bank as ProjectManagement.Models.Bank;
    var transactions = ViewBag.Transactions as IEnumerable<ProjectManagement.Models.Voucher>;
    var fromDate = ViewBag.FromDate != null ? (DateTime)ViewBag.FromDate : DateTime.Today.AddMonths(-1);
    var toDate = ViewBag.ToDate != null ? (DateTime)ViewBag.ToDate : DateTime.Today;
}

<div class="d-print-none">
    <h2><i class="bi bi-bank"></i> Bank Statement</h2>
</div>

<div class="card mb-3">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">
            <i class="bi bi-bank2"></i> @(bank?.Name ?? "Bank") - Account Statement
        </h5>
        <small>Period: @fromDate.ToString("dd-MMM-yyyy") to @toDate.ToString("dd-MMM-yyyy")</small>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-5">Bank Name:</dt>
                    <dd class="col-sm-7">@(bank?.Name ?? "N/A")</dd>

                    <dt class="col-sm-5">Account Number:</dt>
                    <dd class="col-sm-7">@(bank?.AccountNumber ?? "N/A")</dd>

                    <dt class="col-sm-5">Account Details:</dt>
                    <dd class="col-sm-7">@(bank?.Details ?? "N/A")</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card bg-secondary text-white">
                            <div class="card-body text-center">
                                <h6>Opening Balance</h6>
                                @{ decimal ob = ViewBag.OpeningBalance ?? 0; }
                                <h4 class="mb-0">@(ob < 0 ? "-" : "")Rs. @string.Format("{0:N0}", Math.Abs(ob))</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-info text-white">
                            <div class="card-body text-center">
                                <h6>Closing Balance</h6>
                                @{
                                    decimal openingBal = ViewBag.OpeningBalance ?? 0;
                                    decimal cardTotalCredit = 0;
                                    decimal cardTotalDebit = 0;
                                    if (ViewBag.Transactions != null)
                                    {
                                        var cardTransactions = ViewBag.Transactions as IEnumerable<ProjectManagement.Models.Voucher>;
                                        foreach (var t in cardTransactions)
                                        {
                                            if (t.BankCustomerReceiverId == bank?.Id)
                                                cardTotalCredit += t.Amount;
                                            if (t.BankCustomerPaidId == bank?.Id)
                                                cardTotalDebit += t.Amount;
                                        }
                                    }
                                    decimal closingBal = openingBal + cardTotalCredit - cardTotalDebit;
                                }
                                <h4 class="mb-0">@(closingBal < 0 ? "-" : "")Rs. @string.Format("{0:N0}", Math.Abs(closingBal))</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-list-ul"></i> Transaction History</h5>
        <input type="text" id="bankSearchInput" class="form-control form-control-sm" placeholder="Search transactions..." style="width: 250px;" />
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0" id="bankStatementTable">
                <thead class="table-primary">
                    <tr>
                        <th class="fw-bold" style="font-size: 14px;">Date</th>
                        <th class="fw-bold" style="font-size: 14px;">Transaction No</th>
                        <th class="fw-bold" style="font-size: 14px;">Type</th>
                        <th class="fw-bold" style="font-size: 14px;">Description</th>
                        <th class="text-end fw-bold" style="font-size: 14px;">Debit (Withdrawal)</th>
                        <th class="text-end fw-bold" style="font-size: 14px;">Credit (Deposit)</th>
                        <th class="text-end fw-bold" style="font-size: 14px;">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        decimal openingBalance = ViewBag.OpeningBalance != null ? (decimal)ViewBag.OpeningBalance : 0;
                        decimal runningBalance = openingBalance;
                        decimal totalDebit = 0;
                        decimal totalCredit = 0;
                    }

                    <!-- Opening Balance Row -->
                    <tr class="table-warning">
                        <td class="fw-semibold">@fromDate.ToString("dd-MMM-yy")</td>
                        <td colspan="3" class="fw-bold fs-6">Opening Balance</td>
                        <td class="text-end fw-semibold">@(openingBalance < 0 ? string.Format("{0:N0}", Math.Abs(openingBalance)) : "-")</td>
                        <td class="text-end fw-semibold">@(openingBalance > 0 ? string.Format("{0:N0}", openingBalance) : "-")</td>
                        <td class="text-end fw-bold @(openingBalance >= 0 ? "text-success" : "text-danger")">
                            @(openingBalance < 0 ? "-" : "")@string.Format("{0:N0}", Math.Abs(openingBalance))
                        </td>
                    </tr>

                    @if (transactions != null && bank != null)
                    {
                        foreach (var transaction in transactions.OrderBy(t => t.VoucherDate).ThenBy(t => t.Id))
                        {
                            bool isDebit = transaction.BankCustomerPaidId == bank.Id;
                            bool isCredit = transaction.BankCustomerReceiverId == bank.Id;

                            if (isDebit)
                            {
                                runningBalance -= transaction.Amount;
                                totalDebit += transaction.Amount;
                            }
                            else if (isCredit)
                            {
                                runningBalance += transaction.Amount;
                                totalCredit += transaction.Amount;
                            }

                            <tr style="font-size: 13px;">
                                <td class="align-middle">@transaction.VoucherDate.ToPkShortDate()</td>
                                <td class="align-middle">
                                    <a asp-controller="Vouchers" asp-action="Details" asp-route-id="@transaction.Id">
                                        @transaction.TransactionNumber
                                    </a>
                                </td>
                                <td class="align-middle" style="font-size:12px;">
                                    @{
                                        // For BCR: this bank is the receiver — money came FROM the other bank
                                        // For BCR debit: this bank is the payer — money went TO the other bank
                                        if (transaction.VoucherType == ProjectManagement.Models.VoucherType.BCR)
                                        {
                                            if (isCredit && transaction.BankCustomerPaid != null)
                                            {
                                                // This bank received money — show "Received from [other bank]"
                                                var otherBankId = transaction.BankCustomerPaidId;
                                                var otherBankName = transaction.BankCustomerPaid.Name;
                                                <span class="text-success fw-semibold">Received from </span>
                                                <a href="/Reports/BankStatement?bankId=@otherBankId&fromDate=@fromDate.ToString("yyyy-MM-dd")&toDate=@toDate.ToString("yyyy-MM-dd")"
                                                   target="_blank" class="fw-semibold">@otherBankName</a>
                                            }
                                            else if (isDebit && transaction.BankCustomerReceiver != null)
                                            {
                                                // This bank paid money — show "Paid to [other bank]"
                                                var otherBankId = transaction.BankCustomerReceiverId;
                                                var otherBankName = transaction.BankCustomerReceiver.Name;
                                                <span class="text-danger fw-semibold">Paid to </span>
                                                <a href="/Reports/BankStatement?bankId=@otherBankId&fromDate=@fromDate.ToString("yyyy-MM-dd")&toDate=@toDate.ToString("yyyy-MM-dd")"
                                                   target="_blank" class="fw-semibold">@otherBankName</a>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info" style="font-size:11px;">BCR</span>
                                            }
                                        }
                                        else
                                        {
                                            // Non-BCR: show voucher type badge + customer name if available
                                            var customerName = transaction.PurchasingCustomer?.Name
                                                ?? transaction.ReceivingCustomer?.Name;
                                            var customerId = transaction.PurchasingCustomerId
                                                ?? transaction.ReceivingCustomerId;
                                            <span class="badge bg-secondary" style="font-size:11px;">@transaction.VoucherType</span>
                                            if (customerId.HasValue && customerName != null)
                                            {
                                                <br />
                                                <a href="/Reports/CustomerLedger?customerId=@customerId&fromDate=@fromDate.ToString("yyyy-MM-dd")&toDate=@toDate.ToString("yyyy-MM-dd")"
                                                   target="_blank" class="small">@customerName</a>
                                            }
                                        }
                                    }
                                </td>
                                <td class="align-middle">
                                    @(transaction.BankCustomerPaidDetails ?? transaction.BankCustomerReceiverDetails ??
                                    transaction.PurchasingCustomerDetails ?? transaction.ReceivingCustomerDetails ??
                                    "Bank Transaction")
                                </td>
                                <td class="text-end align-middle @(isDebit ? "text-danger fw-semibold" : "")">
                                    @if (isDebit)
                                    {
                                        <span>@string.Format("{0:N0}", transaction.Amount)</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td class="text-end align-middle @(isCredit ? "text-success fw-semibold" : "")">
                                    @if (isCredit)
                                    {
                                        <span>@string.Format("{0:N0}", transaction.Amount)</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td class="text-end align-middle fw-bold @(runningBalance >= 0 ? "text-success" : "text-danger")">
                                    @(runningBalance < 0 ? "-" : "")@string.Format("{0:N0}", Math.Abs(runningBalance))
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4 fst-italic">
                                <i class="bi bi-info-circle"></i> No transactions found for the selected period.
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-success">
                    <tr style="font-size: 15px;">
                        <th colspan="4" class="fw-bold py-3">PERIOD TOTAL:</th>
                        <th class="text-end text-danger fw-bold py-3">Rs. @string.Format("{0:N0}", totalDebit)</th>
                        <th class="text-end text-success fw-bold py-3">Rs. @string.Format("{0:N0}", totalCredit)</th>
                        <th class="text-end"></th>
                    </tr>
                    <tr style="font-size: 15px;">
                        <th colspan="4" class="fw-bold py-3">CLOSING BALANCE (as of @toDate.ToString("dd-MMM-yyyy")):</th>
                        <th colspan="2" class="text-end">
                            @{
                                decimal closingBalance = openingBalance + totalCredit - totalDebit;
                            }
                        </th>
                        <th class="text-end fw-bold py-3 @(closingBalance >= 0 ? "text-success" : "text-danger")">@(closingBalance < 0 ? "-" : "")Rs. @string.Format("{0:N0}", Math.Abs(closingBalance))</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-3 d-print-none">
    <button onclick="window.print()" class="btn btn-primary">
        <i class="bi bi-printer"></i> Print Statement
    </button>
    <button onclick="exportTableToExcel('bankStatementTable', 'BankStatement_@bank?.Name')" class="btn btn-success">
        <i class="bi bi-file-earmark-excel"></i> Export to Excel
    </button>
    <button onclick="generatePDF()" class="btn btn-danger" data-bank-name="@bank?.Name">
        <i class="bi bi-file-pdf"></i> Generate PDF
    </button>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

@section Scripts {
    <!-- html2pdf.js CDN (screenshot-style PDF) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        // Site branding for the PDF footer (set in Theme Settings, saved to sitesettings.json)
        var SITE = {
            name: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.SiteName)),
            showDev: @(site.ShowDeveloperInfo ? "true" : "false"),
            devName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.DeveloperName)),
            devContact: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(site.DeveloperContact))
        };

        // Builds the site-name + (optional) developer footer block appended to the
        // bottom of the cloned report so it appears in the screenshot-style PDF.
        function buildSiteFooter() {
            var wrap = document.createElement('div');
            wrap.style.cssText = 'margin-top:14px;padding-top:8px;border-top:1px solid #999;text-align:center;font-family:Arial,sans-serif;';

            var line1 = document.createElement('div');
            line1.style.cssText = 'font-size:11px;color:#333;font-weight:600;';
            line1.textContent = 'This report was generated by ' + SITE.name + ' Management System';
            wrap.appendChild(line1);

            if (SITE.showDev) {
                var line2 = document.createElement('div');
                line2.style.cssText = 'font-size:10px;color:#666;margin-top:3px;';
                line2.textContent = 'Software developed by ' + SITE.devName + ' — Contact: ' + SITE.devContact + ' for the management software';
                wrap.appendChild(line2);
            }
            return wrap;
        }

        $(document).ready(function() {
            var $rows = $('#bankStatementTable tbody tr:not(.table-warning)');
            var openingBal = @(ViewBag.OpeningBalance != null ? (decimal)ViewBag.OpeningBalance : 0m);

            // Function to update totals based on visible rows
            function updateBankTotals() {
                var totalDebit = 0;
                var totalCredit = 0;
                var closingBal = openingBal;

                // Loop through visible rows
                $rows.each(function() {
                    if ($(this).is(':visible')) {
                        var cells = $(this).find('td');
                        if (cells.length > 0) {
                            var debitCell = cells.eq(4).text().trim();
                            var creditCell = cells.eq(5).text().trim();

                            // Parse values (skip "-")
                            var debit = debitCell !== '-' ? parseFloat(debitCell.replace(/[^\d.]/g, '')) : 0;
                            var credit = creditCell !== '-' ? parseFloat(creditCell.replace(/[^\d.]/g, '')) : 0;

                            debit = isNaN(debit) ? 0 : debit;
                            credit = isNaN(credit) ? 0 : credit;

                            totalDebit += debit;
                            totalCredit += credit;
                        }
                    }
                });

                // Calculate closing balance
                closingBal = openingBal + totalCredit - totalDebit;

                // Update footer totals (first footer row)
                var footerRows = $('#bankStatementTable tfoot tr');
                footerRows.eq(0).find('th').eq(1).text('Rs. ' + totalDebit.toLocaleString('en-PK', {maximumFractionDigits: 0}));
                footerRows.eq(0).find('th').eq(2).text('Rs. ' + totalCredit.toLocaleString('en-PK', {maximumFractionDigits: 0}));

                // Update Closing Balance (second footer row)
                var balanceClass = closingBal >= 0 ? 'text-success' : 'text-danger';
                footerRows.eq(1).find('th').last()
                    .text((closingBal < 0 ? "-" : "") + 'Rs. ' + Math.abs(closingBal).toLocaleString('en-PK', {maximumFractionDigits: 0}))
                    .removeClass('text-success text-danger')
                    .addClass(balanceClass);
            }

            // Search functionality - searches all columns including Debit and Credit
            $('#bankSearchInput').on('keyup', function() {
                var searchTerm = $(this).val().toLowerCase().trim();

                $rows.each(function() {
                    var cells = $(this).find('td');
                    var isVisible = false;

                    // Search through all cells in the row
                    cells.each(function() {
                        var cellText = $(this).text().toLowerCase();
                        if (cellText.includes(searchTerm)) {
                            isVisible = true;
                            return false; // Break the loop
                        }
                    });

                    // Show/hide row based on search match
                    if (searchTerm === '' || isVisible) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });

                // Update totals after filtering
                updateBankTotals();
            });

            // Initialize totals on page load
            updateBankTotals();
        });

        function exportTableToExcel(tableID, filename = ''){
            var downloadLink;
            var dataType = 'application/vnd.ms-excel';
            var tableSelect = document.getElementById(tableID);
            var tableHTML = tableSelect.outerHTML.replace(/ /g, '%20');

            filename = filename?filename+'.xls':'excel_data.xls';
            downloadLink = document.createElement("a");
            document.body.appendChild(downloadLink);

            if(navigator.msSaveOrOpenBlob){
                var blob = new Blob(['\ufeff', tableHTML], {
                    type: dataType
                });
                navigator.msSaveOrOpenBlob( blob, filename);
            }else{
                downloadLink.href = 'data:' + dataType + ', ' + tableHTML;
                downloadLink.download = filename;
                downloadLink.click();
            }
        }

        // Builds a clean clone of just the statement (no navbar/footer/buttons),
        // expanded so html2pdf captures every row and every column, with the site
        // branding footer appended at the bottom.
        function buildPdfElement() {
            const element = document.querySelector('body').cloneNode(true);
            element.style.display = 'block';
            element.style.height = 'auto';

            element.querySelectorAll('header, footer, .modal, .d-print-none')
                   .forEach(el => el.remove());

            // Remove the scrollable/fixed-height container so the full table renders.
            element.querySelectorAll('.table-responsive').forEach(function(el) {
                el.style.maxHeight = 'none';
                el.style.overflow = 'visible';
                el.style.overflowX = 'visible';
                el.style.overflowY = 'visible';
            });

            // Header repeats only where the browser supports it; static so html2canvas
            // measures the full table.
            element.querySelectorAll('#bankStatementTable thead').forEach(t => t.style.display = 'table-header-group');
            element.querySelectorAll('#bankStatementTable thead th').forEach(th => th.style.position = 'static');
            element.querySelectorAll('#bankStatementTable tfoot').forEach(t => t.style.display = 'table-footer-group');

            // Fit all columns to the page width so none are clipped.
            const colWidths = ['11%', '13%', '16%', '20%', '13%', '13%', '14%'];
            element.querySelectorAll('#bankStatementTable').forEach(function(tbl) {
                tbl.style.width = '100%';
                tbl.style.tableLayout = 'fixed';
                const existing = tbl.querySelector('colgroup');
                if (existing) existing.remove();
                const colgroup = document.createElement('colgroup');
                colWidths.forEach(function(w) {
                    const col = document.createElement('col');
                    col.style.width = w;
                    colgroup.appendChild(col);
                });
                tbl.insertBefore(colgroup, tbl.firstChild);
            });
            element.querySelectorAll('#bankStatementTable th, #bankStatementTable td').forEach(function(cell) {
                cell.style.wordBreak = 'break-word';
                cell.style.whiteSpace = 'normal';
                cell.style.overflowWrap = 'anywhere';
                cell.style.fontSize = '11px';
                cell.style.padding = '4px 5px';
                cell.style.verticalAlign = 'middle';
            });

            // Append the site / developer footer at the bottom of the report.
            var main = element.querySelector('main') || element.querySelector('.container-fluid') || element.body || element;
            main.appendChild(buildSiteFooter());

            return element;
        }

        // Generate the screenshot-style PDF (all rows + columns), with the site footer.
        function generatePDF() {
            const button = event.target.closest('button');
            const originalText = button.innerHTML;
            button.innerHTML = '<i class="bi bi-hourglass-split"></i> Generating PDF...';
            button.disabled = true;

            const bankName = button.getAttribute('data-bank-name') || 'Bank';
            const timestamp = new Date().toISOString().slice(0,10).replace(/-/g,'');
            const filename = 'BankStatement_' + bankName.replace(/\s+/g, '_') + '_' + timestamp + '.pdf';

            const element = buildPdfElement();
            const opt = {
                margin: [10, 10, 10, 10],
                filename: filename,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true, logging: false, scrollY: 0, scrollX: 0, windowHeight: element.scrollHeight },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' },
                pagebreak: { mode: ['css', 'legacy'], avoid: 'tr' }
            };

            html2pdf().set(opt).from(element).save().then(function() {
                button.innerHTML = originalText;
                button.disabled = false;
            }).catch(function(error) {
                console.error('PDF generation error:', error);
                button.innerHTML = originalText;
                button.disabled = false;
            });
        }
    </script>

    <style>
        /* Enhanced table styling */
        #bankStatementTable thead th {
            background-color: #cfe2ff !important;
            border-bottom: 2px solid #0d6efd;
            padding: 12px 8px;
        }

        #bankStatementTable tbody tr:hover {
            background-color: #f8f9fa;
        }

        #bankStatementTable {
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        /* No fixed-height scroll container — the table expands to show every row
           so all records are visible on screen and captured in the PDF. */
        .table-responsive {
            max-height: none;
            overflow: visible;
        }

        @@media print {
            .table {
                font-size: 10pt;
            }

            .table-responsive {
                max-height: none;
                overflow: visible;
            }

            #bankStatementTable thead th {
                position: static;
            }

            /* Repeat the table header on every printed page */
            #bankStatementTable thead {
                display: table-header-group;
            }

            #bankStatementTable tfoot {
                display: table-footer-group;
            }

            /* Never split a row across a page boundary */
            #bankStatementTable tr {
                page-break-inside: avoid;
            }
        }
    </style>
}
